<script>
// ============================================
// NAV SCROLL
// ============================================
function scrollToSection(sectionId, navItem) {
  // Update active state
  document.querySelectorAll('.tb-nav-item').forEach(i => i.classList.remove('active'));
  navItem.classList.add('active');
  
  if (sectionId === 'top') {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    return;
  }
  
  const el = document.getElementById(sectionId);
  if (el) {
    const offset = 80; // account for fixed topbar
    const top = el.getBoundingClientRect().top + window.pageYOffset - offset;
    window.scrollTo({ top, behavior: 'smooth' });
  }
}

// ============================================
// SIDEBAR NAVIGATION (page switching)
// ============================================
function sidebarNav(page, sidebarItem) {
  // Update sidebar active state
  document.querySelectorAll('.sb-item').forEach(i => i.classList.remove('active'));
  sidebarItem.classList.add('active');
  
  // Get main content sections
  const dashboardSections = document.querySelectorAll('.hero, .grid-main, .bottom-row');
  const statsPage = document.getElementById('page-stats');
  const calendarPage = document.getElementById('page-calendar');
  
  // Hide all overlays
  statsPage.classList.remove('visible');
  calendarPage.classList.remove('visible');
  
  if (page === 'dashboard') {
    // Show dashboard, hide overlays
    dashboardSections.forEach(s => s.style.display = '');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  } else if (page === 'stats') {
    // Hide dashboard, show stats
    dashboardSections.forEach(s => s.style.display = 'none');
    statsPage.classList.add('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  } else if (page === 'calendar') {
    // Hide dashboard, show calendar
    dashboardSections.forEach(s => s.style.display = 'none');
    calendarPage.classList.add('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
}

// ============================================
// PLANT AI CHAT RESPONSES
// ============================================

const aiResponses = {
  'next-watering': 'The soil moisture in Stadtpark Heilbronn (for roses and lavender) is at 25%, which is below the threshold of 35%. No rain is currently expected, so I recommend watering soon with approximately <b>8 liters of water</b>.',
  'plant-health': 'The plants in Stadtpark Heilbronn, particularly roses and lavender, show an average health score of <b>68.7</b>, indicating a warning status. The trend has deteriorated over the past few days. The current soil moisture at 25% is too low. Immediate watering is therefore <b>strongly recommended</b>. Information on air humidity is currently unavailable.',
  'climate-impact': 'The plants in Stadtpark Heilbronn have consumed a total of <b>119.5 liters of water</b> in the last 30 days. Through smart irrigation, an estimated <b>530 liters of water</b> have been saved. Your contribution to climate protection through CO₂ absorption is approximately <b>0.95 kg</b> during this period.'
};

async function aiChatRespond(action, btnElement) {
  const messagesArea = document.getElementById('aiMessages');
  
  // Disable all chips while processing
  document.querySelectorAll('.ai-chip').forEach(c => c.style.pointerEvents = 'none');
  
  // Add typing indicator
  const typingEl = document.createElement('div');
  typingEl.className = 'ai-typing';
  typingEl.innerHTML = `
    <div class="ai-typing-dots"><span></span><span></span><span></span></div>
    <span class="ai-typing-label">Plant AI is thinking...</span>
  `;
  messagesArea.appendChild(typingEl);
  messagesArea.scrollTop = messagesArea.scrollHeight;
  
  // Fire webhook in background
  const webhookUrl = {
    'next-watering': 'https://workspacesmartconsulting.app.n8n.cloud/webhook/120571b9-62b4-43be-b50b-88639a97495f',
    'plant-health': 'https://workspacesmartconsulting.app.n8n.cloud/webhook/45828e17-7024-4573-b76e-ae72e71c32a6',
    'climate-impact': 'https://workspacesmartconsulting.app.n8n.cloud/webhook-test/007031e5-67a4-4b38-921e-6ca2b449b8bb'
  };
  fetch(webhookUrl[action] || '', {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ message: action })
  }).catch(() => {});

  // Wait 5 seconds
  await new Promise(resolve => setTimeout(resolve, 5000));
  
  // Remove typing indicator
  messagesArea.removeChild(typingEl);
  
  // Add the AI response
  const now = new Date();
  const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  
  const msgEl = document.createElement('div');
  msgEl.className = 'ai-msg';
  msgEl.innerHTML = aiResponses[action];
  messagesArea.appendChild(msgEl);
  
  const timeEl = document.createElement('div');
  timeEl.className = 'ai-time';
  timeEl.textContent = timeStr;
  messagesArea.appendChild(timeEl);
  
  messagesArea.scrollTop = messagesArea.scrollHeight;
  
  // Re-enable chips
  document.querySelectorAll('.ai-chip').forEach(c => c.style.pointerEvents = '');
}

// ============================================
// WEBHOOK INTEGRATION FOR n8n WORKFLOWS
// ============================================

async function triggerWebhook(action, btnElement) {
  const chatbox = document.getElementById('webhookChatbox');
  const messagesContainer = document.getElementById('webhookMessages');
  
  // Show chatbox
  chatbox.classList.add('visible');
  
  // Set loading state on button
  const originalHTML = btnElement.innerHTML;
  const label = btnElement.textContent.trim();
  btnElement.classList.add('loading');
  btnElement.innerHTML = '<span class="spinner"></span> Running...';
  
  // Add "thinking" message
  const thinkingMsg = document.createElement('div');
  thinkingMsg.className = 'webhook-msg';
  thinkingMsg.innerHTML = `
    <div class="msg-label">
      <span class="spinner" style="width:10px;height:10px;border-width:1.5px;"></span>
      ${label}
    </div>
    <span style="color:var(--text-muted);font-size:12px;">Running workflow...</span>
  `;
  messagesContainer.appendChild(thinkingMsg);
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
  
  // Get the webhook URL and fire it in the background
  const webhookUrl = btnElement.getAttribute('data-webhook-url');
  const webhookMessages = {
    'next-watering': 'Nächste Bewässerung Heilbronn',
    'plant-health': 'Pflanzengesundheit Check Heilbronn',
    'climate-impact': 'Klimatischer Impact Heilbronn'
  };
  
  // Fire webhook call (don't await — just trigger it)
  fetch(webhookUrl, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ message: webhookMessages[action] || action })
  }).catch(() => {});

  // Predefined responses per button
  const responses = {
    'next-watering': 'Die Bodenfeuchtigkeit im Stadtpark Heilbronn (für Rosa und Lavendel) liegt bei 25%, was unter dem Schwellenwert von 35% liegt. Es wird aktuell kein Regen erwartet, daher empfehle ich eine Bewässerung in Kürze mit etwa <b>8 Litern Wasser</b>.',
    'plant-health': 'Die Pflanzen im Stadtpark Heilbronn, insbesondere Rosen und Lavendel, zeigen einen Health-Score von durchschnittlich <b>68.7</b>, was auf einen Warnstatus hindeutet. Der Trend hat sich in den letzten Tagen verschlechtert. Die aktuelle Bodenfeuchtigkeit ist mit 25% zu niedrig. Eine sofortige Bewässerung ist daher <b>dringend empfohlen</b>. Informationen zur Luftfeuchtigkeit sind derzeit nicht verfügbar.',
    'climate-impact': 'Die Pflanzen im Stadtpark Heilbronn haben in den letzten 30 Tagen insgesamt <b>119.5 Liter Wasser</b> verbraucht. Durch smarte Bewässerung konnten schätzungsweise <b>530 Liter Wasser</b> eingespart werden. Ihr Beitrag zum Klimaschutz durch CO₂-Absorption liegt bei etwa <b>0.95 kg</b> in diesem Zeitraum.'
  };

  // Wait 5 seconds to simulate workflow processing
  await new Promise(resolve => setTimeout(resolve, 5000));

  // Remove thinking message and show response
  messagesContainer.removeChild(thinkingMsg);
  
  const now = new Date();
  const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  
  const resultMsg = document.createElement('div');
  resultMsg.className = 'webhook-msg';
  resultMsg.innerHTML = `
    <div class="msg-label">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
      ${label}
    </div>
    <span>${responses[action]}</span>
    <div class="msg-time">${timeStr}</div>
  `;
  messagesContainer.appendChild(resultMsg);
  
  // Reset button
  btnElement.classList.remove('loading');
  btnElement.innerHTML = originalHTML;
  
  // Scroll to latest message
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
}
</script>
